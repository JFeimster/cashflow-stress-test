  "qa_suite": {
    "required_checks": [
      "Every scenario contains exactly one fictional business.",
      "Receivables moved between weeks are removed from the original week.",
      "Repair, rental, replacement, and outsourcing choices are not combined unless explicitly intended.",
      "Revenue protected by outsourcing is not also counted as lost revenue.",
      "Insurance proceeds are counted only in the modeled receipt week.",
      "Available credit remains separate until an intentional draw is modeled.",
      "Beginning cash chains from the prior week ending cash.",
      "Funding gap uses the protected minimum, not zero.",
      "Recovery week means cash returns to the defined threshold under the stated assumptions.",
      "No scenario implies funding approval or insurance reimbursement."
