{
  "schema_name": "worked_local_business_cash_flow_scenarios",
  "schema_version": "1.0.0",
  "product": "Cash Flow Stress-Test Copilot",
  "fictional_data_notice": "All businesses, values, customers, dates, and events in this file are fictional and are provided only for testing, demonstration, and QA.",
  "shared_rules": {
    "forecast_horizon_weeks": 13,
    "currency": "USD",
    "available_credit_is_cash": false,
    "insurance_proceeds_counted_before_receipt_week": false,
    "ending_cash_formula": "beginning_cash + total_cash_inflows - total_cash_outflows",
    "funding_gap_formula": "max(0, protected_minimum_cash - lowest_projected_cash)"
  },
  "scenarios": [
    {
      "scenario_id": "contractor_001",
      "business_profile": {
        "business_name": "Blue Ridge HVAC Services",
        "business_type": "HVAC contractor",
        "location": "Fictional Mid-Atlantic market",
        "current_available_cash": 42000,
        "protected_minimum_cash": 18000,
        "green_safety_buffer": 5000,
        "available_reserve_cash": 12000,
        "available_credit": 25000,
        "payroll_schedule": [
          {
            "week": 2,
            "amount": 14500
          },
          {
            "week": 4,
            "amount": 14500
          },
          {
            "week": 6,
            "amount": 14500
          },
          {
            "week": 8,
            "amount": 14500
          },
          {
            "week": 10,
            "amount": 14500
          },
          {
            "week": 12,
            "amount": 14500
          }
        ]
      },
      "baseline_summary": {
        "normal_weekly_cash_inflows": 28000,
        "normal_weekly_cash_outflows": 24600,
        "lowest_projected_cash": 42000,
        "first_week_below_protected_minimum": null,
        "first_negative_cash_week": null
      },
      "stress_scenario": {
        "name": "Slow demand plus service-truck failure",
        "type": "stacked_shock",
        "adjustments": [
          {
            "week": 3,
            "line_item": "cash_sales",
            "adjustment_type": "remove_inflow",
            "amount": 5600,
            "note": "20% revenue decline"
          },
          {
            "week": 4,
            "line_item": "cash_sales",
            "adjustment_type": "remove_inflow",
            "amount": 5600,
            "note": "20% revenue decline"
          },
          {
            "week": 4,
            "line_item": "repairs_replacement",
            "adjustment_type": "add_outflow",
            "amount": 12500,
            "note": "Truck repair and towing"
          },
          {
            "week": 4,
            "line_item": "cash_sales",
            "adjustment_type": "remove_inflow",
            "amount": 4800,
            "note": "Five days of lost field capacity"
          },
          {
            "week": 5,
            "line_item": "temporary_operating_cost",
            "adjustment_type": "add_outflow",
            "amount": 2400,
            "note": "Temporary vehicle rental"
          }
        ],
        "assumptions": [
          "No insurance proceeds are assumed.",
          "Revenue recovers to baseline in Week 6.",
          "Available credit is not counted as cash.",
          "Reserve cash remains unused in the first stress run."
        ],
        "expected_qa_checks": [
          "Week 4 includes both reduced revenue and repair outflow without duplicating the same lost jobs.",
          "Beginning cash in Week 5 equals ending cash in Week 4.",
          "Available credit does not increase ending cash.",
          "The response-lever test may separately model a reserve transfer."
        ]
      },
      "response_levers": [
        {
          "name": "Collect overdue receivables",
          "amount": 9000,
          "week": 4
        },
        {
          "name": "Transfer reserve cash",
          "amount": 8000,
          "week": 4
        },
        {
          "name": "Negotiate repair payment",
          "amount_delayed": 5000,
          "from_week": 4,
          "to_week": 6
        }
      ],
      "documents": [
        "repair estimate",
        "truck downtime estimate",
        "AR aging",
        "payroll schedule",
        "bank statements",
        "use-of-funds schedule"
      ]
    },
