{
  "schema_name": "cash_flow_stress_test_industry_risk_profiles",
  "schema_version": "1.0.0",
  "product": "Cash Flow Stress-Test Copilot",
  "purpose": "Illustrative industry-specific risk prompts, scenario variables, document requests, triggers, and response levers for local-business cash-flow stress testing.",
  "important_notice": "The values and ranges in this file are scenario defaults for demonstrations and missing-data prompts. They are not industry benchmarks, underwriting standards, approval criteria, or predictions. Use user-provided and source-verified values whenever available.",
  "global_rules": {
    "forecast_horizon_weeks": 13,
    "currency_default": "USD",
    "available_credit_is_cash": false,
    "insurance_proceeds_before_receipt_week": false,
    "funding_gap_formula": "max(0, protected_minimum_cash - lowest_projected_cash)",
    "required_revenue_classes": [
      "lost",
      "delayed",
      "protected",
      "unknown"
    ],
    "required_cost_classes": [
      "fixed",
      "variable",
      "direct_disruption",
      "temporary_operating",
      "recovery",
      "financing",
      "unknown"
    ],
    "confidence_values": [
      "confirmed",
      "estimated",
      "unknown"
    ]
  },
